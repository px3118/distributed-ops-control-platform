{
  "name": "distributed-ops-control-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Reference implementation of a distributed operations control platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspace apps/api",
    "dev:api": "npm run dev --workspace apps/api",
    "dev:web": "npm run dev --workspace apps/web",
    "dev:simulator": "npm run dev --workspace apps/simulator",
    "db:migrate": "npm run db:migrate --workspace apps/api",
    "db:seed": "npm run seed --workspace apps/api",
    "test": "npm run test --workspaces --if-present",
    "test:e2e": "playwright test",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "postcss": "^8.5.6",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
